# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_PATH=
NODE_ENV=development

# Clerk auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard
BROKERAGE_PORTAL_DEV_AUTH_BYPASS=0

# Optional Clerk organization id mapping for server-verified workspace access.
# If absent locally, the dashboard uses a development-only preview fallback.
CLERK_ORG_REALA_ID=
CLERK_ORG_VENDOR_NETWORK_ID=
CLERK_ORG_ENGEL_VOLKERS_ID=
CLERK_ORG_NORTH_GROUP_ID=
CLERK_ORG_REALA_CLIENT_ID=

# Portal Supabase
# This is the new portal application database, not the MLS/read-only Supabase source.
PORTAL_SUPABASE_PROJECT_REF=
NEXT_PUBLIC_PORTAL_SUPABASE_PROJECT_REF=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
DATABASE_URL=

# Future MLS/listing prefill adapter
# Keep this separate from the portal DB.
MLS_SUPABASE_URL=
MLS_SUPABASE_SERVICE_ROLE_KEY=
MLS_DATABASE_URL=
MLS_SUPABASE_LISTING_TABLE=ListingInventory

# Read-only Google Sheets mirror for `/legacy-sheets`.
# Prefer JSON in production secret storage; use a local path for development only.
GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEETS_SERVICE_ACCOUNT_PATH=

# Future storage adapter: Cloudflare R2, S3, or another object store.
STORAGE_PROVIDER=demo
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Future payments adapter
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Future monitoring
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Future legacy adapter boundaries
LEGACY_WRITE_MODE=off
LEGACY_BRIDGE_TEST_PREFIX=TEST-PORTAL-
LEGACY_REALA_API_BASE_URL=
LEGACY_REALA_API_KEY=
SIGNTRAKER_API_BASE_URL=
SIGNTRAKER_API_KEY=
TIMETAP_API_BASE_URL=
TIMETAP_API_KEY=
