{
  "name": "reala",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:marketing": "next dev",
    "dev:chatbot": "pnpm --filter @reala/chatbot dev",
    "dev:brokerage": "pnpm --filter @reala/brokerage-portal dev",
    "build": "next build",
    "build:marketing": "next build",
    "build:brokerage": "pnpm --filter @reala/brokerage-portal build",
    "start": "next start",
    "lint": "eslint src",
    "lint:brokerage": "pnpm --filter @reala/brokerage-portal lint",
    "lint:all": "pnpm lint && pnpm lint:brokerage",
    "typecheck": "tsc --noEmit",
    "test": "echo \"Run app-specific checks with pnpm --filter @reala/chatbot test or pnpm --filter @reala/brokerage-portal lint.\""
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
